# ── Replica counts (number of containers per service) ─────────────────────────
gateway_replicas=3
order_replicas=3
payment_replicas=3
stock_replicas=3

# ── Gateway uvicorn workers per instance ──────────────────────────────────────
# Total gateway processes = gateway_replicas × gateway_workers
gateway_workers=2

# ── Redis shards per service ───────────────────────────────────────────────────
# Format: host:port,host:port,...
# To change shard count:
#   1. Add/remove db container definitions in docker-compose.yml
#   2. Update the list below to match
order_shards=order-db-0:6379,order-db-1:6379,order-db-2:6379
payment_shards=payment-db-0:6379,payment-db-1:6379,payment-db-2:6379
stock_shards=stock-db-0:6379,stock-db-1:6379,stock-db-2:6379
